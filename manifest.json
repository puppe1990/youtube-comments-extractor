{
  "manifest_version": 3,
  "name": "YouTube Comments Extractor",
  "version": "1.0.0",
  "description": "Carrega comentarios do YouTube e exporta comentarios com respostas ligadas ao comentario pai.",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Extrair comentarios",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*", "https://m.youtube.com/watch*"],
      "js": ["src/extractor-core.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
